# Core project settings
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Optional for components that still use API-key mode
GEMINI_API_KEY=

# Optional Gemini model overrides (defaults are set in config.py)
GEMINI_PRO_MODEL=gemini-3-flash-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview

# Live model override (optional)
MODEL_LIVE=publishers/google/models/gemini-live-2.5-flash-native-audio
GEMINI_LIVE_MODEL=

# Firestore vector search embedding dimension (Firestore max is 2048)
EMBEDDING_DIMENSION=768

# Vertex AI embedding model (GA; available in global)
MODEL_EMBEDDING=text-embedding-005

# MCP Google Calendar server auth
# Preferred: path to OAuth desktop credentials JSON for @cocal/google-calendar-mcp
GOOGLE_OAUTH_CREDENTIALS=

# Optional alternative credentials for MCP servers that support refresh-token auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Required for the web UI Google OAuth redirect flow (/auth/google/start)
# Use any long random string locally.
SATARK_AUTH_STATE_SECRET=

# Optional but recommended when behind a proxy (Cloud Run). For local dev this can be:
SATARK_PUBLIC_BASE_URL=http://127.0.0.1:8080

# Optional Google MCP forwarding headers (JSON string)
OPENAPI_MCP_HEADERS=

# Optional calendar settings
GOOGLE_CALENDAR_ID=primary
SATARK_CALENDAR_TIMEZONE=Asia/Kolkata

# Optional credentials file path (if needed by your local tooling)
GOOGLE_APPLICATION_CREDENTIALS=

# Optional threat intel key
ABUSEIPDB_API_KEY=

# ─── AlloyDB (optional – only if using AlloyDB instead of Firestore) ────────
ALLOYDB_REGION=
ALLOYDB_CLUSTER=
ALLOYDB_INSTANCE=
ALLOYDB_DATABASE=
ALLOYDB_USER=
ALLOYDB_PASSWORD=

# ─── CORS (comma-separated origins, default "*" for dev) ───────────────────
# SATARK_CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ─── Performance tuning ────────────────────────────────────────────────────
# SATARK_STARTUP_WARMUP=1
# SATARK_ARTIFACT_CACHE_MAX_ITEMS=128
# SATARK_ADK_PIPELINE_TIMEOUT_S=8
